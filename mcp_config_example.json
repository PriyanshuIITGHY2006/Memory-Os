{
  "mcpServers": {
    "memoryos": {
      "command": "python",
      "args": ["-m", "backend.mcp_server"],
      "cwd": "/path/to/memory-os",
      "env": {
        "MEMORYOS_USER_ID":  "YOUR_USER_ID_HERE",
        "MEMORYOS_GROQ_KEY": "YOUR_GROQ_API_KEY_HERE",
        "NEO4J_URI":         "neo4j+ssc://YOUR_NEO4J_INSTANCE",
        "NEO4J_USER":        "YOUR_NEO4J_USER",
        "NEO4J_PASSWORD":    "YOUR_NEO4J_PASSWORD"
      }
    }
  }
}
